---
import SignOutButton from '../auth/SignOutButton';
import ThemeToggle from './ThemeToggle';

interface Props {
  current: 'dashboard' | 'history' | 'profile' | 'new';
  email: string;
}

const { current, email } = Astro.props;

const linkBase = 'px-3 inline-flex items-center min-h-10 rounded-md text-sm font-medium';
const linkActive = 'bg-neutral-900 text-white dark:bg-white dark:text-neutral-900';
const linkIdle = 'text-neutral-600 hover:bg-neutral-100 dark:text-neutral-400 dark:hover:bg-neutral-800';

const cls = (key: Props['current']) => `${linkBase} ${current === key ? linkActive : linkIdle}`;
---

<header class="border-b border-neutral-200 dark:border-neutral-800">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-3 px-6 py-3 sm:px-8">
    <nav class="flex items-center gap-1">
      <a href="/" class={cls('dashboard')}>Dashboard</a>
      <a href="/history" class={cls('history')}>History</a>
      <a href="/profile" class={cls('profile')}>Profile</a>
    </nav>
    <div class="flex items-center gap-2">
      <span class="hidden text-xs text-neutral-500 sm:inline">{email}</span>
      <ThemeToggle client:load />
      <SignOutButton client:load />
    </div>
  </div>
</header>
