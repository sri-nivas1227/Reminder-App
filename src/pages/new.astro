---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavHeader from '../components/layout/NavHeader.astro';
import NewTaskClient from '../components/tasks/NewTaskClient';
import { listCategories } from '../lib/db/queries';

const user = Astro.locals.user!;
const cats = await listCategories(user.id);
---

<BaseLayout title="New task · Reminder App">
  <NavHeader current="new" email={user.email} />
  <main class="mx-auto max-w-xl p-6">
    <a href="/" class="text-sm text-neutral-500 hover:underline">← Back to dashboard</a>
    <h1 class="mt-4 text-2xl font-semibold tracking-tight">New task</h1>
    <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
      Set a recurring reminder.
    </p>
    <div class="mt-6 rounded-lg border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
      <NewTaskClient client:load categories={cats} />
    </div>
  </main>
</BaseLayout>
