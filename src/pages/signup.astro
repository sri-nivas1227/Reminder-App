---
import BaseLayout from '../layouts/BaseLayout.astro';
import SignupForm from '../components/auth/SignupForm';
---

<BaseLayout title="Sign up · Reminder App">
  <main class="mx-auto flex min-h-screen max-w-md flex-col justify-center p-6">
    <div class="rounded-lg border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
      <h1 class="text-2xl font-semibold tracking-tight">Create account</h1>
      <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
        Set up reminders for the things you keep forgetting.
      </p>
      <div class="mt-6">
        <SignupForm client:load />
      </div>
      <p class="mt-4 text-sm text-neutral-600 dark:text-neutral-400">
        Already registered? <a href="/login" class="font-medium text-indigo-600 hover:underline">Sign in</a>
      </p>
    </div>
  </main>
</BaseLayout>
