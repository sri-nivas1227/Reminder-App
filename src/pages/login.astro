---
import BaseLayout from '../layouts/BaseLayout.astro';
import LoginForm from '../components/auth/LoginForm';

const next = Astro.url.searchParams.get('next') ?? '/';
---

<BaseLayout title="Sign in · Reminder App">
  <main class="mx-auto flex min-h-screen max-w-md flex-col justify-center p-6">
    <div class="rounded-lg border border-neutral-200 bg-white p-6 shadow-sm dark:border-neutral-800 dark:bg-neutral-900">
      <h1 class="text-2xl font-semibold tracking-tight">Sign in</h1>
      <p class="mt-1 text-sm text-neutral-600 dark:text-neutral-400">
        Welcome back. Sign in to your account.
      </p>
      <div class="mt-6">
        <LoginForm client:load next={next} />
      </div>
      <p class="mt-4 text-sm text-neutral-600 dark:text-neutral-400">
        No account? <a href="/signup" class="font-medium text-indigo-600 hover:underline">Sign up</a>
      </p>
    </div>
  </main>
</BaseLayout>
