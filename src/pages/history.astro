---
import BaseLayout from '../layouts/BaseLayout.astro';
import NavHeader from '../components/layout/NavHeader.astro';
import { db } from '../lib/db/client';
import { task } from '../lib/db/schema';
import { eq } from 'drizzle-orm';
import { listHistory, perTaskStats } from '../lib/db/historyQueries';

const user = Astro.locals.user!;
const params = Astro.url.searchParams;

const taskIdParam = params.get('taskId') ?? '';
const statusParam = params.get('status') ?? '';
const fromParam = params.get('from') ?? '';
const toParam = params.get('to') ?? '';

const filter: Parameters<typeof listHistory>[1] = {};
if (taskIdParam) filter.taskId = taskIdParam;
if (statusParam === 'done' || statusParam === 'missed' || statusParam === 'pending') {
  filter.status = statusParam;
}
if (fromParam) filter.from = new Date(fromParam);
if (toParam) {
  // Inclusive end-of-day
  const d = new Date(toParam);
  d.setDate(d.getDate() + 1);
  filter.to = d;
}

const [tasks, history, perTask] = await Promise.all([
  db.query.task.findMany({ where: eq(task.userId, user.id) }),
  listHistory(user.id, filter),
  perTaskStats(user.id),
]);

const inputCls =
  'block w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm shadow-sm dark:border-neutral-700 dark:bg-neutral-900';

const statusBadge = (s: string) =>
  s === 'done'
    ? 'bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300'
    : s === 'missed'
      ? 'bg-red-100 text-red-800 dark:bg-red-900/40 dark:text-red-300'
      : 'bg-neutral-100 text-neutral-700 dark:bg-neutral-800 dark:text-neutral-300';
---

<BaseLayout title="History · Reminder App">
  <NavHeader current="history" email={user.email} />
  <main class="mx-auto max-w-5xl p-6 sm:p-8">
    <h1 class="text-3xl font-semibold tracking-tight">History</h1>

    <section class="mt-6">
      <h2 class="text-lg font-semibold">Per-task stats</h2>
      {perTask.length === 0 ? (
        <p class="mt-2 text-sm text-neutral-500">No tasks yet.</p>
      ) : (
        <div class="mt-3 overflow-x-auto rounded-lg border border-neutral-200 dark:border-neutral-800">
          <table class="min-w-full divide-y divide-neutral-200 text-sm dark:divide-neutral-800">
            <thead class="bg-neutral-50 dark:bg-neutral-900">
              <tr>
                <th class="px-3 py-2 text-left font-medium">Task</th>
                <th class="px-3 py-2 text-right font-medium text-emerald-700 dark:text-emerald-400">Done</th>
                <th class="px-3 py-2 text-right font-medium text-red-700 dark:text-red-400">Missed</th>
                <th class="px-3 py-2 text-right font-medium">Pending</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-neutral-100 dark:divide-neutral-800">
              {perTask.map((r) => (
                <tr>
                  <td class="px-3 py-2">{r.title}</td>
                  <td class="px-3 py-2 text-right">{r.done}</td>
                  <td class="px-3 py-2 text-right">{r.missed}</td>
                  <td class="px-3 py-2 text-right">{r.pending}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </section>

    <section class="mt-10">
      <h2 class="text-lg font-semibold">Occurrence log</h2>
      <form method="get" class="mt-3 grid gap-3 rounded-lg border border-neutral-200 bg-white p-4 sm:grid-cols-4 dark:border-neutral-800 dark:bg-neutral-900">
        <div>
          <label class="block text-xs font-medium">Task</label>
          <select name="taskId" class={inputCls + ' mt-1'}>
            <option value="">All</option>
            {tasks.map((t) => (
              <option value={t.id} selected={t.id === taskIdParam}>{t.title}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium">Status</label>
          <select name="status" class={inputCls + ' mt-1'}>
            <option value="">All</option>
            {['pending', 'done', 'missed'].map((s) => (
              <option value={s} selected={s === statusParam}>{s}</option>
            ))}
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium">From</label>
          <input type="date" name="from" value={fromParam} class={inputCls + ' mt-1'} />
        </div>
        <div>
          <label class="block text-xs font-medium">To</label>
          <input type="date" name="to" value={toParam} class={inputCls + ' mt-1'} />
        </div>
        <div class="sm:col-span-4 flex gap-2">
          <button type="submit" class="rounded-md bg-indigo-600 px-3 py-1.5 text-sm font-medium text-white hover:bg-indigo-700">
            Apply
          </button>
          <a href="/history" class="rounded-md border border-neutral-300 px-3 py-1.5 text-sm hover:bg-neutral-100 dark:border-neutral-700 dark:hover:bg-neutral-800">
            Clear
          </a>
        </div>
      </form>

      <div class="mt-4 overflow-x-auto rounded-lg border border-neutral-200 dark:border-neutral-800">
        <table class="min-w-full divide-y divide-neutral-200 text-sm dark:divide-neutral-800">
          <thead class="bg-neutral-50 dark:bg-neutral-900">
            <tr>
              <th class="px-3 py-2 text-left font-medium">When</th>
              <th class="px-3 py-2 text-left font-medium">Task</th>
              <th class="px-3 py-2 text-left font-medium">Category</th>
              <th class="px-3 py-2 text-left font-medium">Status</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100 dark:divide-neutral-800">
            {history.length === 0 ? (
              <tr><td colspan="4" class="px-3 py-6 text-center text-sm text-neutral-500">No matches.</td></tr>
            ) : (
              history.map((r) => (
                <tr>
                  <td class="whitespace-nowrap px-3 py-2 text-neutral-600 dark:text-neutral-400">
                    {new Date(r.scheduledFor).toLocaleString([], {
                      month: 'short',
                      day: 'numeric',
                      year: 'numeric',
                      hour: 'numeric',
                      minute: '2-digit',
                    })}
                  </td>
                  <td class="px-3 py-2">{r.title}</td>
                  <td class="px-3 py-2">
                    {r.categoryName ? (
                      <span
                        class="rounded-full px-2 py-0.5 text-xs font-medium text-white"
                        style={`background-color: ${r.categoryColor ?? '#6366f1'}`}
                      >
                        {r.categoryName}
                      </span>
                    ) : (
                      <span class="text-neutral-400">—</span>
                    )}
                  </td>
                  <td class="px-3 py-2">
                    <span class={'rounded-full px-2 py-0.5 text-xs font-medium ' + statusBadge(r.status)}>
                      {r.status}
                    </span>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
    </section>
  </main>
</BaseLayout>
