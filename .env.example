# Database
DATABASE_URL=postgres://user:pass@localhost:5432/reminder_app

# Auth (generate AUTH_SECRET: openssl rand -base64 32)
AUTH_SECRET=replace-with-32-char-min-random-string-xxxxx
AUTH_URL=http://localhost:4321

# Email (Resend) — optional in dev
RESEND_API_KEY=
RESEND_FROM_EMAIL=reminders@example.com

# SMS (Twilio) — optional in dev
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Cron protection (any random 16+ char string)
CRON_SECRET=

# Minutes before scheduled time to fire reminder (default 5)
REMINDER_LEAD_MINUTES=5

NODE_ENV=development
